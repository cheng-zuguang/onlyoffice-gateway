# =============================================================================
# ONLYOFFICE Gateway Configuration
# =============================================================================
# 复制为 gateway.yaml 并调整：
#   cp gateway.yaml.example gateway.yaml
#
# Docker Compose 部署：
#   document_server_url 填 "http://document-server"
#   listen_addr 填 "0.0.0.0:18080"
#   jwt_secret 通过环境变量 JWT_SECRET 注入，此处留空即可

listen_addr: "0.0.0.0:18080"
document_server_url: "http://document-server"
jwt_secret: ""
storage_dir: "./data/storage"
ttl_hours: 8
webhook_max_retries: 3

services:
  - id: "your-service-name"
    public_key: |
      -----BEGIN PUBLIC KEY-----
      YOUR_RSA_PUBLIC_KEY_HERE
      -----END PUBLIC KEY-----
    allowed_webhook_domains:
      - "your-app.example.com"
