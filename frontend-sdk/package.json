{
  "name": "@zenmind-sdk/onlyoffice-editor",
  "version": "0.2.0",
  "description": "Thin React wrapper for ONLYOFFICE editor iframe",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18.3.1",
    "react-dom": ">=18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "jsdom": "25.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run sync-version && npm run build",
    "sync-version": "node sync-version.mjs",
    "test": "vitest run"
  }
}
