# =============================================================================
# ONLYOFFICE Gateway + Document Server — 环境变量配置
# =============================================================================
# 复制为 .env 后修改：
#   cp .env.example .env
#
# 一键启动（含管理端）：
#   docker compose up -d
# =============================================================================

# ── Gateway ───────────────────────────────────────────────────────────────────
LISTEN_ADDR=0.0.0.0:18080
DOCUMENT_SERVER_URL=http://document-server
# 与 Document Server 共享，仅用于 ONLYOFFICE 编辑器配置 JWT
DOCUMENT_SERVER_JWT_SECRET=
# 仅 Gateway 使用；以下三个值必须彼此独立，也不能复用上面的 JWT secret
GATEWAY_ADMIN_SESSION_SECRET=
GATEWAY_CALLBACK_CAPABILITY_SECRET=
# Base64 编码的 32 字节 AES-256-GCM 主密钥，用于加密每服务 webhook 凭证
WEBHOOK_SECRET_ENCRYPTION_KEY=
STORAGE_BACKEND=local
STORAGE_DIR=./data/storage
TTL_HOURS=8
# 本地过期文件扫描间隔；YAML 中同样支持 15m、1h 这样的时长写法
CLEANUP_INTERVAL=1h
WEBHOOK_MAX_RETRIES=3
# 保存回调的有界队列与并发 worker；队列满时任务被拒绝并计入 metrics
CALLBACK_QUEUE_SIZE=64
CALLBACK_WORKERS=4

# ── S3 / MinIO Storage (set STORAGE_BACKEND=s3 to enable) ────────────────────
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=onlyoffice
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true
S3_USE_SSL=false
S3_PREFIX=documents

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SERVICE_STORE_PATH=./data/services.json
ADMIN_AUDIT_LOG_DIR=./data/audit
ADMIN_AUDIT_LOG_RETENTION_DAYS=14

# ── Admin UI (nginx container port) ───────────────────────────────────────────
GATEWAY_PORT=18080
ADMIN_UI_PORT=18081

# ── Document Server ──────────────────────────────────────────────────────────
DS_PORT=18000
DS_LOG_LEVEL=warn
ALLOW_PRIVATE_IP_ADDRESS=true
ALLOW_META_IP_ADDRESS=true
USE_UNAUTHORIZED_STORAGE=true
EXAMPLE_ENABLED=true
METRICS_ENABLED=false
GENERATE_FONTS=true
WOPI_ENABLED=false
