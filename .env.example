# =============================================================================
# ONLYOFFICE Gateway + Document Server — 环境变量配置
# =============================================================================
# 复制为 .env 后修改：
#   cp .env.example .env
#
# 一键启动（含管理端）：
#   docker compose up -d
# =============================================================================

# ── Gateway ───────────────────────────────────────────────────────────────────
LISTEN_ADDR=0.0.0.0:18080
DOCUMENT_SERVER_URL=http://document-server
JWT_SECRET=
STORAGE_DIR=./data/storage
TTL_HOURS=8
WEBHOOK_MAX_RETRIES=3

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SERVICE_STORE_PATH=./data/services.json

# ── Admin UI (nginx container port) ───────────────────────────────────────────
GATEWAY_PORT=18080
ADMIN_UI_PORT=18081

# ── Document Server ──────────────────────────────────────────────────────────
DS_PORT=18000
DS_LOG_LEVEL=warn
ALLOW_PRIVATE_IP_ADDRESS=true
ALLOW_META_IP_ADDRESS=true
USE_UNAUTHORIZED_STORAGE=true
EXAMPLE_ENABLED=true
METRICS_ENABLED=false
GENERATE_FONTS=true
WOPI_ENABLED=false
