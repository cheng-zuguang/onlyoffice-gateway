# =============================================================================
# ONLYOFFICE Gateway + Document Server — 环境变量配置
# =============================================================================
# 1. 复制本文件：cp .env.example .env
# 2. 生成 4 个独立密钥：make init-secrets
# 3. 至少设置 ADMIN_PASSWORD，再执行：docker compose up -d
#
# 标有「必填」的配置不可留空；生产环境还应逐项复核「重要」配置。
# =============================================================================

# ── 必填：安全凭证（优先配置）────────────────────────────────────────────────

# [必填] ONLYOFFICE 编辑器配置 JWT 的签名密钥；Gateway 与 Document Server 共用。
DOCUMENT_SERVER_JWT_SECRET=

# [必填] 管理端登录 Session JWT 的签名密钥；不得与其他密钥复用。
GATEWAY_ADMIN_SESSION_SECRET=

# [必填] Document Server 回调地址的 capability 签名密钥；不得与其他密钥复用。
GATEWAY_CALLBACK_CAPABILITY_SECRET=

# [必填] 加密各业务服务 webhook 凭证的主密钥；值为 Base64 编码的 32 字节密钥。
WEBHOOK_SECRET_ENCRYPTION_KEY=

# [必填] 管理端登录密码；请设置高强度密码，禁止在生产环境使用示例值。
ADMIN_PASSWORD=

# ── 重要：访问地址与管理员账号 ──────────────────────────────────────────────

# Gateway 监听地址；直接运行 Gateway 时生效，Docker Compose 内固定为 0.0.0.0:18080。
LISTEN_ADDR=0.0.0.0:18080

# Gateway 访问 Document Server 的内部地址；Compose 服务间通信使用此默认值。
DOCUMENT_SERVER_URL=http://document-server

# 浏览器直连 Document Server 的公开地址；留空时由浏览器通过 Gateway 反向代理访问。
# 仅在希望绕过 Gateway 代理、通过独立域名或端口加载编辑器资源时设置。
DOCUMENT_SERVER_PUBLIC_URL=

# 管理端登录用户名。
ADMIN_USERNAME=admin

# 宿主机暴露的 Gateway API 端口。
GATEWAY_PORT=18080

# 宿主机暴露的管理端 UI 端口。
ADMIN_UI_PORT=18081

# 宿主机暴露的 Document Server 端口。
DS_PORT=18000

# ── Gateway：本地存储与生命周期 ─────────────────────────────────────────────

# 存储后端，可选 local 或 s3；选择 s3 时需配置下方 S3 参数。
STORAGE_BACKEND=local

# 本地存储目录；直接运行 Gateway 时生效，Compose 内映射到 /app/data。
STORAGE_DIR=./data/storage

# 单次上传大小上限（字节）；默认 104857600，即 100 MiB。
MAX_UPLOAD_BYTES=104857600

# 托管文档保留时长（小时），到期后由清理任务删除。
TTL_HOURS=8

# 过期文件扫描间隔，使用 Go duration 格式，例如 15m、1h。
CLEANUP_INTERVAL=1h

# 业务 webhook 投递失败后的最大重试次数。
WEBHOOK_MAX_RETRIES=3

# Document Server 保存回调的有界队列容量；队列满时拒绝新任务并记录指标。
CALLBACK_QUEUE_SIZE=64

# 并发处理 Document Server 保存回调的 worker 数量。
CALLBACK_WORKERS=4

# 业务服务注册信息的持久化文件路径；Compose 内固定为 /app/data/services.json。
SERVICE_STORE_PATH=./data/services.json

# 管理操作审计日志目录；Compose 内固定为 /app/data/audit。
ADMIN_AUDIT_LOG_DIR=./data/audit

# 管理操作审计日志的保留天数。
ADMIN_AUDIT_LOG_RETENTION_DAYS=14

# ── S3 / MinIO（仅 STORAGE_BACKEND=s3 时配置）───────────────────────────────

# S3 兼容服务端点；使用 Compose 的 MinIO profile 时保持默认值。
S3_ENDPOINT=http://minio:9000

# S3 区域；MinIO 通常可使用 us-east-1。
S3_REGION=us-east-1

# 存放文档的 bucket 名称。
S3_BUCKET=onlyoffice

# S3 Access Key；生产环境请替换默认凭证。
S3_ACCESS_KEY=minioadmin

# S3 Secret Key；生产环境请替换默认凭证。
S3_SECRET_KEY=minioadmin

# 是否使用 path-style URL；MinIO 通常设为 true。
S3_USE_PATH_STYLE=true

# Gateway 连接 S3 端点时是否启用 TLS；仅可信内网 HTTP 端点可设为 false。
S3_USE_SSL=false

# bucket 内的对象键前缀；不要以 / 开头或结尾。
S3_PREFIX=documents

# ── Document Server：高级选项 ───────────────────────────────────────────────

# Document Server 日志级别，例如 error、warn、info、debug。
DS_LOG_LEVEL=warn

# 是否允许 Document Server 访问私有 IP；仅在受信任内网部署时开启。
ALLOW_PRIVATE_IP_ADDRESS=true

# 是否允许 Document Server 访问元数据地址；有云元数据泄露风险，生产环境建议关闭。
ALLOW_META_IP_ADDRESS=true

# 是否允许访问使用不受信任 TLS 证书的存储地址；生产环境建议关闭。
USE_UNAUTHORIZED_STORAGE=true

# 是否启用 Document Server 自带示例应用；生产环境建议关闭。
EXAMPLE_ENABLED=true

# 是否启用 Document Server 内置指标采集。
METRICS_ENABLED=false

# 容器启动时是否重新生成字体缓存；挂载自定义字体时需开启。
GENERATE_FONTS=true

# 是否启用 WOPI 协议；本 Gateway 默认不需要。
WOPI_ENABLED=false
