# =============================================================================
# ONLYOFFICE Gateway + Document Server — 环境变量配置
# =============================================================================
# 复制为 .env 后修改：
#   cp .env.example .env
#
# 一键启动：
#   docker compose up -d
# =============================================================================

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=18080

# ── Document Server ──────────────────────────────────────────────────────────
DS_PORT=8080

# ── 共享 JWT Secret（Gateway + Document Server 必须一致）────────────────────
# 留空则自动生成；生产环境务必自定义
JWT_SECRET=

# ── JWT 鉴权 ─────────────────────────────────────────────────────────────────
JWT_ENABLED=true
# JWT_HEADER=Authorization
# JWT_IN_BODY=false

# ── 日志级别 ─────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error
DS_LOG_LEVEL=warn

# ── 网络 / 安全 ─────────────────────────────────────────────────────────────
ALLOW_PRIVATE_IP_ADDRESS=true   # 允许 Document Server 访问内网地址
ALLOW_META_IP_ADDRESS=true      # 允许元数据 IP 地址
USE_UNAUTHORIZED_STORAGE=true   # 允许连接未认证的存储后端

# ── 预览优化 ─────────────────────────────────────────────────────────────────
EXAMPLE_ENABLED=true            # 示例页面
METRICS_ENABLED=false           # 指标采集

# ── 字体 ─────────────────────────────────────────────────────────────────────
GENERATE_FONTS=true             # 启动时生成字体索引

# ── WOPI ────────────────────────────────────────────────────────────────────
WOPI_ENABLED=false

# ── 企业版数据库（社区版忽略）────────────────────────────────────────────────
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=onlyoffice
# DB_USER=onlyoffice
# DB_PWD=onlyoffice
